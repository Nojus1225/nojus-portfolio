RewriteEngine On

# =========================
# 1. PHP files without .php extension
# =========================

# If it opens with the .php extension
RewriteCond %{THE_REQUEST} \s/([^.]+)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# If a file exists with .php, allow it to be accessed without the extension
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([a-zA-Z0-9_-]+)$ $1.php [L]

# =========================
# 2. Block sensitive files
# =========================

<FilesMatch "\.(env|json|db|sql|log)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Additional protection (direct titles)
<FilesMatch "^(\.env|config\.php|database\.db|composer\.json)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# =========================
# 3. Disable directory listing
# =========================

Options -Indexes

# =========================
# 4. Redirect protection (optional clean URLs)
# =========================

# If you want /about to work as /about.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L]

# =========================
# 5. Simple protection against access to cookies / system files
# =========================

<FilesMatch "(\.htaccess|\.htpasswd)">
    Order allow,deny
    Deny from all
</FilesMatch>